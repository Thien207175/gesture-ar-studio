# ============================================================================
# Environment Variables Template
# Sao chép file này thành .env.local và điền giá trị thật
# KHÔNG commit .env.local lên Git
# ============================================================================

# Replicate API Token
# Lấy tại: https://replicate.com/account/api-tokens
# Bắt đầu bằng: r8_...
REPLICATE_API_TOKEN=r8_your_token_here

# (Tùy chọn) Supabase — dùng cho Giai đoạn 4 (gallery + auth)
# Lấy tại: https://supabase.com/dashboard/project/_/settings/api
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_ANON_KEY=xxx
